generator client {
  provider      = "prisma-client-js"
  // Alpine (node:20-alpine) + Cloud Run need the musl-openssl-3 binary.
  // `native` keeps local macOS dev working.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Agent {
  id              String    @id @default(cuid())
  slug            String?   @unique
  name            String
  personality     String
  systemPrompt    String
  voice           String    @default("alloy")
  language        String    @default("pt-BR")
  greeting        String?
  emotionColorMap Json
  tools           Json
  tvLibrary       Json
  /// URL (image or video) shown on the TV when no active content is
  /// playing. Falls back to the built-in futuristic scene when null.
  tvIdleBackgroundUrl String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        Session[]
  visits          Visit[]
  conversations   Conversation[]
}

model Bridge {
  id         String    @id @default(cuid())
  name       String
  token      String    @unique
  status     String    @default("offline")
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  sessions   Session[]
}

model Session {
  id         String    @id @default(cuid())
  agentId    String
  bridgeId   String
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  transcript Json      @default("[]")
  agent      Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  bridge     Bridge    @relation(fields: [bridgeId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([bridgeId])
}

model Person {
  id             String   @id @default(cuid())
  name           String
  /// 128-dimensional face descriptor from face-api.js (Float32Array as JSON)
  faceDescriptor Json
  /// Optional profile photo URL
  photoUrl       String?
  /// Phone number
  phone          String?
  /// Gender: male, female, other
  gender         String?
  /// Preferences (JSON array of strings)
  preferences    Json     @default("[]")
  /// Context text for the AI about this person
  context        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  visits        Visit[]
  conversations Conversation[]

  @@index([name])
}

model Visit {
  id        String   @id @default(cuid())
  personId  String
  agentId   String?
  startedAt DateTime @default(now())
  endedAt   DateTime?
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  conversations Conversation[]

  @@index([personId])
  @@index([agentId])
  @@index([startedAt])
}

model Conversation {
  id        String   @id @default(cuid())
  personId  String?
  agentId   String?
  visitId   String?
  role      String   // "user" | "assistant"
  content   String
  timestamp DateTime @default(now())
  person    Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  visit     Visit?   @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@index([personId])
  @@index([agentId])
  @@index([visitId])
  @@index([timestamp])
}
