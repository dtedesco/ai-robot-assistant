# API
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/robot?schema=public
JWT_SECRET=change-me-to-a-long-random-string
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_VOICE=shimmer
BRIDGE_REALTIME_INSTRUCTIONS=Você é Robert, um robô amigo muito simpático, divertido e curioso. Fale em português brasileiro de forma natural, animada e conversacional. Respostas curtas e diretas.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Bridge
BRIDGE_TOKEN=generated-in-admin-ui
API_WS_URL=ws://localhost:3000/ws/bridge
BRIDGE_NAME=my-bridge
# Local debug UI (localhost only; set HOST=0.0.0.0 to expose on LAN, e.g. on Pi)
LOCAL_HTTP_HOST=127.0.0.1
LOCAL_HTTP_PORT=3100
# Auto-open Realtime on welcome (bridge pulls OpenAI key/model from the API)
REALTIME_AUTO_START=true

# Web
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
